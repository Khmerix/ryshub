[node name="Content" type="RichTextLabel" parent="UI/HelpPanel/VBox"]
layout_mode = 2
size_flags_vertical = 3
theme_override_font_sizes/normal_font_size = 12
text = "[b]Tools:[/b]
• Build (1) - Place blocks
• Paint (2) - Change block colors  
• Erase (3) - Remove blocks
• Select (4) - Select blocks (Delete to remove)

[b]Controls:[/b]
• Left Click - Use current tool
• Right Click + Drag - Pan camera
• Middle Click + Drag - Rotate camera
• Scroll - Zoom in/out
• R - Rotate ghost block
• Ctrl+Z / Ctrl+Y - Undo / Redo

[b]Tips:[/b]
• Use Grid/Snap for precise building
• Try different environments for unique looks
• Save your builds regularly!"

